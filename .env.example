# 注意：环境变量/.env 仅作为「初始默认值」。一旦存在 config.yml（由管理 Web UI 写入），
# 同名项以 config.yml 为准（优先级：config.yml > 环境变量 > 硬编码默认）。
# 可用 CONFIG_FILE 指定 config.yml 路径（默认 ./config.yml）。

# 对外上传 API 监听端口
PORT=3000

# 控制面板端口（监听 0.0.0.0）。访问范围由部署者通过防火墙/NAT 控制。
# 端口公开后，/api/config 因能改写配置（含 STORAGE_TOKEN）需要 Bearer token。
ADMIN_PORT=3001

# 客户端要带上的 token
STORAGE_TOKEN=replace-me-with-a-long-random-string

# 文件落盘目录（相对 cwd 的路径）
UPLOAD_DIR=./uploads

# 返回给客户端的 URL 拼接基址
# 本地开发: http://localhost:3000
# 部署后:   https://your-domain.com
PUBLIC_BASE_URL=http://localhost:3000

# 单个文件最大字节数（默认 10MB）
MAX_FILE_SIZE=10485760

# 持久化 worker 数量（默认 4）
WORKER_COUNT=4

# 任务队列容量（默认 64）
QUEUE_SIZE=64
